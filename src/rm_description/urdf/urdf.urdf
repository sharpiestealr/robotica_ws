<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- ==================== -->
  <!-- BASE FOOTPRINT       -->
  <!-- ==================== -->
  <!-- Link virtual no chão (Z=0), sem geometria -->
  <link name="base_footprint">
  </link>

  <!-- ==================== -->
  <!-- BASE LINK            -->
  <!-- ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <!-- Inércia de um cilindro: ixx=iyy=(1/12)*m*(3r²+h²), izz=(1/2)*m*r² -->
      <inertia
        ixx="0.00520833"
        ixy="0.0" ixz="0.0"
        iyy="0.00520833"
        iyz="0.0"
        izz="0.01"/>
    </inertial>
  </link>

  <!-- Joint conectando base_footprint ao base_link -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

  <link name="caixa">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry> <box size=".5 1 0.1"/> </geometry>
    <material name="gray"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry> <box size=".5 1 0.1"/> </geometry>
  </collision>
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.084166667" ixy="0" ixz="0" iyy="0.021666667" iyz="0" izz="0.1041666667"/>
  </inertial>
</link>

<joint name="base_caixa" type="fixed">
    <parent link="base_link"/>
    <child link="caixa"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

  <link name="rodaL">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry> <cylinder radius=".15" length=".1"/> </geometry>
    <material name="gray"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry> <cylinder radius=".15" length=".1"/> </geometry>
  </collision>
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.006458333" ixy="0" ixz="0" iyy="0.006458333" iyz="0" izz="0.01125"/>
  </inertial>
</link>

<joint name="caixa_rodaL" type="continuous">
    <parent link="caixa"/>
    <child link="rodaL"/>
    <origin xyz="0 0.55 0" rpy="300 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rodaR">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry> <cylinder radius=".15" length=".1"/> </geometry>
    <material name="gray"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry> <cylinder radius=".15" length=".1"/> </geometry>
  </collision>
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.006458333" ixy="0" ixz="0" iyy="0.006458333" iyz="0" izz="0.01125"/>
  </inertial>
</link>

<joint name="caixa_rodaR" type="continuous">
    <parent link="caixa"/>
    <child link="rodaR"/>
    <origin xyz="0 -.55 0" rpy="300 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="head">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry> <sphere radius="0.15"/> </geometry>
    <material name="gray"/>
  </visual>
  <collision>
    <origin xyz="0 -0 0" rpy="0 0 0"/>
    <geometry> <sphere radius="0.15"/> </geometry>
  </collision>
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
  </inertial>
</link>

<joint name="caixa_head" type="fixed">
    <parent link="caixa"/>
    <child link="head"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
  </joint>

</robot>